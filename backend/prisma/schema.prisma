datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
// Field definitions are aligned into columns separated by 2 or more spaces

model User {
    id                  String          @id @default(cuid())
    auth0Id             String          @unique // OAUTH Connection
    createdAt           DateTime        @default(now())
    name                String
    role                Role[]          @default([AGENT])
    email               String          @unique
    phone               String?         @unique
    marketCenterId      String
    marketCenter        MarketCenter    @relation(fields: [marketCenterId], references: [id]) // 1 user → 1 market center 
    ticketsCreated      Ticket[]        @relation("TicketCreator")
    ticketsAssigned     Ticket[]        @relation("TicketAssignee")
    comments            Comments[]
}

model Ticket {
    id                  String                  @id @default(cuid())
    createdAt           DateTime        @default(now())
    dueDate             DateTime?
    updatedAt           DateTime
    resolvedAt          DateTime?
    creator             User                    @relation("TicketCreator", fields: [creatorId], references: [id]) // 1 ticket → 1 creator
    creatorId           String
    assignee            User                    @relation("TicketAssignee", fields: [assigneeId], references: [id]) // 1 ticket → 1 assignment
    assigneeId          String
    marketCenter        MarketCenter            @relation(fields: [marketCenterId], references: [id]) // 1 ticket → 1 market center
    marketCenterId      String
    title               String
    description         String?
    category            String
    priority            Priority
    comments            Comments[]
    status              TicketStatus            @default(CREATED)
    statusHistory       TicketStatusHistory[]
    internal            Boolean                 @default(true)
}

model MarketCenter {
    id              String          @id @default(uuid())
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    name            String
    code            String          @unique
    region          String
    timezone        String
    address1        String
    address2        String?
    city            String
    state           String
    zip             String
    phone           String
    email           String
    tickets         Ticket[]
    users           User[]
}

model Comments {
    id          String          @id @default(cuid())
    createdAt   DateTime        @default(now())
    userId      String
    user        User            @relation(fields: [userId], references: [id])
    ticketId    String
    ticket      Ticket          @relation(fields: [ticketId], references: [id])
    type        CommentType
    content     String
    internal    Boolean         @default(true)
    @@unique([userId, ticketId])
}
model TicketStatusHistory {
    id          String        @id @default(cuid())
    updatedAt   DateTime      @default(now())
    ticketId    String
    ticket      Ticket        @relation(fields: [ticketId], references: [id])
    status      TicketStatus
}

enum Role {
    ADMIN
    AGENT
    STAFF
}

enum TicketStatus {
    CREATED
    ASSIGNED
    IN_PROGRESS
    AWAITING_RESPONSE
    PENDING
    RESOLVED
    CLOSED
    CANCELLED
}

enum Priority {
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

enum CommentType {
    CANCEL
    FEEDBACK
    FOLLOW_UP
    ISSUE
    NOTE
    REMINDER
    QUESTION
}