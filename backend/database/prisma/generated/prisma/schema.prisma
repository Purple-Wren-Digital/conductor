// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  auth0Id           String     @unique // OAUTH Connection
  createdAt         DateTime   @default(now())
  name              String
  role              UserRole[] @default([AGENT])
  email             String     @unique
  phone             String?    @unique
  marketCenterId    String
  createdTickets    String[]
  assignedToTickets String[]
  comments          String[]
}

model Ticket {
  id             String                @id @default(cuid())
  createdAt      DateTime              @default(now())
  dueDate        DateTime?
  updatedAt      DateTime
  resolvedAt     DateTime?
  creatorId      String
  assigneeId     String
  marketCenterId String
  title          String
  description    String?
  category       Category
  urgency        Urgency
  comments       Comments[]
  status         TicketStatus          @default(CREATED)
  statusHistory  TicketStatusHistory[]
  internal       Boolean               @default(true)
}

model Comments {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  userId    String
  ticketId  String
  ticket    Ticket      @relation(fields: [ticketId], references: [id])
  type      CommentType
  content   String
  internal  Boolean     @default(true)

  @@unique([userId, ticketId])
}

model TicketStatusHistory {
  id        String       @id @default(cuid())
  updatedAt DateTime     @default(now())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id])
  status    TicketStatus
}

enum Category {
  DOCUMENT
  GENERAL_INQUIRY
  MAINTENANCE
  OFFER_SUBMISSION
  TOUR_REQUEST
}

enum TicketStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  PENDING
  CLOSED
  CANCELLED
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommentType {
  CANCEL
  FEEDBACK
  FOLLOW_UP
  ISSUE
  NOTE
  REMINDER
  QUESTION
}

enum UserRole {
  ADMIN
  AGENT
  STAFF
}
