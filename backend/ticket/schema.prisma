generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
  seed          = "tsx seed/seed-prisma.ts"
}

datasource db {
  provider          = "postgresql"
  url               = env("DB_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model MarketCenter {
  id                  String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String
  settings            Json                  @default("{}")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")
  marketCenterHistory MarketCenterHistory[]
  subscription        Subscription?
  teamInvitations     TeamInvitation[]
  ticketCategories    TicketCategory[]
  surveys             Survey[]
  users               User[]

  @@map("market_centers")
}

model User {
  id                   String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                String                @unique
  name                 String?
  role                 UserRole              @default(AGENT)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @default(now()) @updatedAt @map("updated_at")
  deletedAt            DateTime?
  isActive             Boolean               @default(true)
  marketCenterId       String?               @map("market_center_id")
  clerkId              String                @unique(map: "users_auth0Id_key") @map("clerk_id")
  marketCenterHistory  MarketCenterHistory[] @relation("MarketCenterChangedBy")
  notifications        Notification[]
  ticketHistory        TicketHistory[]
  otherUsersChanges    UserHistory[]         @relation("ChangedBy")
  userHistory          UserHistory[]         @relation("UpdatedUser")
  userSettings         UserSettings?         @relation("UserToUserSettings")
  attachments          Attachment[]
  comments             Comment[]
  defaultForCategories TicketCategory[]
  receivedSurveys      Survey[]              @relation("UserReceivedRatings")
  givenSurveys         Survey[]              @relation("UserGivenRatings")
  assignedTickets      Ticket[]              @relation("TicketAssignee")
  createdTickets       Ticket[]              @relation("TicketCreator")
  todosCreated         Todo[]                @relation("TodoCreatedBy")
  todosUpdated         Todo[]                @relation("TodoUpdatedBy")
  marketCenter         MarketCenter?         @relation(fields: [marketCenterId], references: [id])

  @@index([marketCenterId])
  @@map("users")
}

model Ticket {
  id            String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  title         String?
  description   String?
  status        TicketStatus?   @default(CREATED)
  urgency       Urgency?        @default(MEDIUM)
  creatorId     String          @map("creator_id")
  assigneeId    String?         @map("assignee_id")
  dueDate       DateTime?       @map("due_date")
  resolvedAt    DateTime?       @map("resolved_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  publishedAt   DateTime?
  categoryId    String?         @map("category_id")
  surveyId      String?         @map("survey_id")
  ticketHistory TicketHistory[]
  attachments   Attachment[]
  comments      Comment[]
  Survey        Survey?
  assignee      User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  category      TicketCategory? @relation(fields: [categoryId], references: [id])
  creator       User            @relation("TicketCreator", fields: [creatorId], references: [id])
  todos         Todo[]

  @@index([creatorId])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
  @@index([surveyId])
  @@map("tickets")
}

model Comment {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  content   String
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  internal  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
  @@map("comments")
}

model Attachment {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileName   String   @map("file_name")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  bucketKey  String   @unique @map("bucket_key")
  ticketId   String   @map("ticket_id")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  @@index([ticketId])
  @@index([uploadedBy])
  @@map("attachments")
}

model TicketCategory {
  id                String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  description       String?
  marketCenterId    String       @map("market_center_id")
  defaultAssigneeId String?      @map("default_assignee_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at")
  defaultAssignee   User?        @relation(fields: [defaultAssigneeId], references: [id])
  marketCenter      MarketCenter @relation(fields: [marketCenterId], references: [id], onDelete: Cascade)
  tickets           Ticket[]

  @@unique([marketCenterId, name])
  @@index([marketCenterId])
  @@map("ticket_categories")
}

model Todo {
  id          String   @id @default(uuid())
  title       String
  complete    Boolean
  ticketId    String   @map("ticket_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById String   @map("created_by_user_id")
  updatedById String?  @map("updated_by_user_id")
  created_by  Json     @default("{}")
  updated_by  Json?
  createdBy   User     @relation("TodoCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation("TodoUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([complete])
  @@index([createdById])
  @@index([updatedById])
  @@map("todos")
}

model TeamInvitation {
  id             String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  email          String
  role           UserRole         @default(AGENT)
  status         InvitationStatus @default(PENDING)
  marketCenterId String?          @map("market_center_id")
  invitedBy      String?          @map("invited_by")
  token          String           @unique
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @default(now()) @updatedAt @map("updated_at")
  marketCenter   MarketCenter?    @relation(fields: [marketCenterId], references: [id], onDelete: Cascade)

  @@unique([marketCenterId, email])
  @@index([token])
  @@index([expiresAt])
  @@map("team_invitations")
}

model Survey {
  id                 String        @id @unique @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId           String        @unique @map("ticket_id")
  comment            String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime?     @updatedAt @map("updated_at")
  surveyorId         String        @map("surveyor_id")
  assigneeRating     Decimal?      @db.Decimal(3, 2)
  marketCenterRating Decimal?      @db.Decimal(3, 2)
  overallRating      Decimal?      @db.Decimal(3, 2)
  assigneeId         String?       @map("assignee_id")
  marketCenterId     String?       @map("market_center_id")
  completed          Boolean       @default(false)
  assignee           User?         @relation("UserReceivedRatings", fields: [assigneeId], references: [id], onDelete: Cascade)
  marketCenter       MarketCenter? @relation(fields: [marketCenterId], references: [id], onDelete: Cascade)
  surveyor           User          @relation("UserGivenRatings", fields: [surveyorId], references: [id], onDelete: Cascade)
  ticket             Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([surveyorId])
  @@index([assigneeId])
  @@index([marketCenterId])
  @@map("ticket_ratings")
}

model TicketHistory {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId      String   @map("ticket_id")
  field         String?
  previousValue String?
  newValue      String?
  snapshot      Json?
  changedAt     DateTime @default(now())
  changedById   String   @map("changed_by_id")
  action        String   @default("UPDATE")
  changedBy     User     @relation(fields: [changedById], references: [id])
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([changedById])
}

model UserHistory {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  marketCenterId String?  @map("market_center_id")
  field          String?
  previousValue  String?
  newValue       String?
  snapshot       Json?
  changedAt      DateTime @default(now())
  changedById    String?  @map("changed_by_id")
  userId         String
  action         String   @default("UPDATE")
  changedBy      User?    @relation("ChangedBy", fields: [changedById], references: [id])
  user           User     @relation("UpdatedUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([changedById])
}

model MarketCenterHistory {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  marketCenterId String       @map("market_center_id")
  field          String?
  previousValue  String?
  newValue       String?
  snapshot       Json?
  changedAt      DateTime     @default(now())
  changedById    String?      @map("changed_by_id")
  action         String       @default("UPDATE")
  changedBy      User?        @relation("MarketCenterChangedBy", fields: [changedById], references: [id])
  marketCenter   MarketCenter @relation(fields: [marketCenterId], references: [id])

  @@index([changedById])
  @@index([marketCenterId])
}

model UserSettings {
  id                      String                    @id @unique @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  userId                  String                    @unique
  notificationPreferences NotificationPreferences[]
  user                    User                      @relation("UserToUserSettings", fields: [userId], references: [id])

  @@index([userId])
}

model NotificationPreferences {
  id             String                @id @unique @default(cuid())
  type           String
  email          Boolean               @default(true)
  push           Boolean               @default(true)
  inApp          Boolean               @default(true)
  userSettingsId String
  category       NotificationCategory  @default(ACCOUNT)
  frequency      NotificationFrequency
  sms            Boolean               @default(false)
  userSettings   UserSettings          @relation(fields: [userSettingsId], references: [id])

  @@index([userSettingsId])
}

model Notification {
  id          String               @id @default(cuid())
  userId      String
  channel     NotificationChannel
  category    NotificationCategory
  priority    Urgency?
  type        String
  title       String
  body        String
  data        Json?
  read        Boolean              @default(false)
  deliveredAt DateTime?
  createdAt   DateTime             @default(now())
  user        User                 @relation(fields: [userId], references: [id])
}

model NotificationTemplate {
  id                  String               @id @default(cuid())
  templateName        String               @unique
  templateDescription String
  category            NotificationCategory
  channel             NotificationChannel
  type                String
  subject             String
  body                String
  isDefault           Boolean              @default(true)
  createdAt           DateTime             @default(now())
  variables           Json?
}

model Subscription {
  id                   String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  stripeSubscriptionId String                @unique @map("stripe_subscription_id")
  stripeCustomerId     String                @map("stripe_customer_id")
  marketCenterId       String                @unique @map("market_center_id")
  status               SubscriptionStatus
  planType             SubscriptionPlan
  priceId              String                @map("price_id")
  includedSeats        Int                   @default(5) @map("included_seats")
  additionalSeats      Int                   @default(0) @map("additional_seats")
  seatPrice            Decimal               @default(10.00) @map("seat_price") @db.Decimal(10, 2)
  currentPeriodStart   DateTime              @map("current_period_start")
  currentPeriodEnd     DateTime              @map("current_period_end")
  cancelAt             DateTime?             @map("cancel_at")
  canceledAt           DateTime?             @map("canceled_at")
  trialEnd             DateTime?             @map("trial_end")
  features             Json                  @default("{}")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  invoices             SubscriptionInvoice[]
  usageRecords         SubscriptionUsage[]
  marketCenter         MarketCenter          @relation(fields: [marketCenterId], references: [id])

  @@index([marketCenterId])
  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionUsage {
  id             String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  subscriptionId String       @map("subscription_id")
  month          DateTime     @map("month")
  activeSeats    Int          @map("active_seats")
  ticketsCreated Int          @default(0) @map("tickets_created")
  storageUsedMb  Int          @default(0) @map("storage_used_mb")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, month])
  @@index([subscriptionId])
  @@index([month])
  @@map("subscription_usage")
}

model SubscriptionInvoice {
  id              String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  subscriptionId  String        @map("subscription_id")
  stripeInvoiceId String        @unique @map("stripe_invoice_id")
  amountDue       Decimal       @map("amount_due") @db.Decimal(10, 2)
  amountPaid      Decimal       @map("amount_paid") @db.Decimal(10, 2)
  currency        String        @default("usd")
  status          InvoiceStatus
  lineItems       Json          @map("line_items")
  periodStart     DateTime      @map("period_start")
  periodEnd       DateTime      @map("period_end")
  dueDate         DateTime?     @map("due_date")
  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@map("subscription_invoices")
}

model schema_migrations {
  version BigInt  @id
  dirty   Boolean
}

enum NotificationCategory {
  ACCOUNT
  ACTIVITY
  MARKETING
  PRODUCT
  PERMISSIONS
}

enum NotificationFrequency {
  NONE
  INSTANT
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  PAUSED
  TRIALING
  UNPAID
}

enum SubscriptionPlan {
  STARTER
  TEAM
  BUSINESS
  ENTERPRISE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
  SMS
}

enum UserRole {
  AGENT
  STAFF
  STAFF_LEADER
  ADMIN
}

enum TicketStatus {
  ASSIGNED
  AWAITING_RESPONSE
  IN_PROGRESS
  RESOLVED
  DRAFT
  CREATED
  UNASSIGNED
}

enum Urgency {
  HIGH
  MEDIUM
  LOW
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum CommentSource {
  WEB
  EMAIL
  API
}
