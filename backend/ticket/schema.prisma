generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model MarketCenter {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  settings          Json               @default("{}")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")
  // settingsAuditLogs SettingsAuditLog[]
  teamInvitations   TeamInvitation[]
  ticketCategories  TicketCategory[]
  users             User[]
  marketCenterHistory  MarketCenterHistory[]

  @@map("market_centers")
}

model User {
  id                   String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                String             @unique
  name                 String?
  role                 UserRole           @default(AGENT)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt            DateTime?
  isActive             Boolean            @default(true)
  marketCenterId       String?            @map("market_center_id")
  auth0Id              String             @unique
  comments             Comment[]
  // auditLogs            SettingsAuditLog[]
  defaultForCategories TicketCategory[]
  assignedTickets      Ticket[]           @relation("TicketAssignee")
  createdTickets       Ticket[]           @relation("TicketCreator")
  marketCenter         MarketCenter?      @relation(fields: [marketCenterId], references: [id])
  ticketHistory        TicketHistory[]
  userHistory          UserHistory[]      @relation("UpdatedUser") // one user can have many history records about *themselves*
  otherUsersChanges    UserHistory[]      @relation("ChangedBy") // one user can also be the "changer" for many others
  marketCenterHistory  MarketCenterHistory[] @relation("MarketCenterChangedBy")

  @@index([marketCenterId])
  @@map("users")
}

model Ticket {
  id          String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  title       String?
  description String?
  status      TicketStatus?    @default(CREATED)
  urgency     Urgency?         @default(MEDIUM)
  categoryId  String?          @map("category_id")
  category    TicketCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creatorId   String           @map("creator_id")
  assigneeId  String?          @map("assignee_id")
  dueDate     DateTime?        @map("due_date")
  resolvedAt  DateTime?        @map("resolved_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")
  publishedAt DateTime?
  comments    Comment[]
  assignee    User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  creator     User            @relation("TicketCreator", fields: [creatorId], references: [id])
  ticketHistory TicketHistory[]

  @@index([creatorId])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([status])
  @@index([urgency])
  @@index([createdAt])
  @@map("tickets")
}

model Comment {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  content   String
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  internal  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
  @@map("comments")
}

model TicketCategory {
  id                 String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  name               String
  description        String?
  marketCenterId     String         @map("market_center_id")
  defaultAssigneeId  String?        @map("default_assignee_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at")
  defaultAssignee    User?          @relation(fields: [defaultAssigneeId], references: [id])
  marketCenter       MarketCenter   @relation(fields: [marketCenterId], references: [id], onDelete: Cascade)
  tickets            Ticket[]      

  @@unique([marketCenterId, name])
  @@index([marketCenterId])
  @@map("ticket_categories")
}

model TeamInvitation {
  id             String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  email          String
  role           UserRole         @default(AGENT)
  status         InvitationStatus @default(PENDING)
  marketCenterId String?           @map("market_center_id")
  invitedBy      String?          @map("invited_by")
  token          String           @unique
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @default(now()) @updatedAt @map("updated_at")
  marketCenter   MarketCenter?     @relation(fields: [marketCenterId], references: [id], onDelete: Cascade)

  @@unique([marketCenterId, email])
  @@index([token])
  @@index([expiresAt])
  @@map("team_invitations")
}

