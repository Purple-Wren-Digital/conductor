model TicketHistory {
  id               String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId         String     @map("ticket_id")
  action           String     @default("UPDATE")
  field            String?
  previousValue    String?
  newValue         String?
  snapshot         Json?         
  changedAt        DateTime   @default(now())
  changedById      String     @map("changed_by_id")

  ticket           Ticket     @relation(fields: [ticketId], references: [id])
  changedBy   User    @relation(fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedById])
}

model UserHistory {
  id               String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String
  marketCenterId   String?    @map("market_center_id")
  action           String     @default("UPDATE")
  field            String?
  previousValue    String?
  newValue         String?
  snapshot         Json?         
  changedAt        DateTime   @default(now())
  changedById      String?    @map("changed_by_id")

  user             User       @relation("UpdatedUser", fields: [userId], references: [id])
  changedBy        User?      @relation("ChangedBy", fields: [changedById], references: [id])

  // marketCenter     User?    @relation(fields: [marketCenterId], references: [id])

  @@index([userId])
  @@index([changedById])
  // @@index([marketCenterId])
}

model MarketCenterHistory {
  id               String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  marketCenterId   String     @map("market_center_id")
  action           String     @default("UPDATE")
  field            String?
  previousValue    String?
  newValue         String?
  snapshot         Json?         
  changedAt        DateTime   @default(now())
  changedById      String?    @map("changed_by_id")

  marketCenter     MarketCenter @relation(fields: [marketCenterId], references: [id])
  changedBy        User?      @relation("MarketCenterChangedBy", fields: [changedById], references: [id])

  @@index([changedById])
  @@index([marketCenterId])

}


enum UserRole {
  AGENT
  STAFF
  ADMIN
}

enum TicketStatus {
  CREATED
  ASSIGNED
  UNASSIGNED
  AWAITING_RESPONSE
  IN_PROGRESS
  RESOLVED
  DRAFT
}

enum Urgency {
  HIGH
  MEDIUM
  LOW
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}
